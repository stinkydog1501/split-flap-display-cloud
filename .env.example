# --- Server ---
PORT=3000
NODE_ENV=production

# 32+ random bytes, base64. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=replace-me-with-a-long-random-string

# Set to true when serving over HTTPS (Cloudflare Tunnel, behind a TLS terminator).
# Must be true in production — required for secure session cookies.
COOKIE_SECURE=true

# --- Google OAuth ---
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_CALLBACK_URL exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public URL of this app as users reach it (e.g. https://splitflap.example.com).
# Used to construct the OAuth callback if GOOGLE_CALLBACK_URL is left blank.
PUBLIC_BASE_URL=
# Optional override. If blank, derived from PUBLIC_BASE_URL + /auth/google/callback.
GOOGLE_CALLBACK_URL=

# --- Allow-list ---
# Comma-separated list of Google account emails that may sign in.
# Matching is case-insensitive and trimmed. Anyone else is rejected after OAuth.
ALLOWED_EMAILS=

# --- MQTT / split-flap display ---
# Address of the MQTT broker on the home network, reachable from this container.
# In Docker compose, the host name resolves via the user's LAN DNS or is passed
# via extra_hosts (see docker-compose.yml). For local dev, use the .local mDNS name.
MQTT_BROKER_URL=mqtt://rpi41.local:1883
MQTT_TOPIC=splitflap/splitflap/set
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=splitflap-display-cloud

# Max characters accepted from the user. The display handles long messages via
# on-device word-aligned chunking, but we still cap total input to keep the UI sane.
MAX_MESSAGE_LENGTH=64

# --- Logging ---
LOG_LEVEL=info